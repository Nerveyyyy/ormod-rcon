# ══════════════════════════════════════════════════════════════════════════════
# ORMOD:Directive RCON Dashboard — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and edit the values below.
#
# LOCAL DEV (Vite on :5173, API on :3000, your own Postgres):
#     1. fill the three REQUIRED secrets
#     2. pnpm --filter @ormod/database db:migrate
#     3. pnpm dev
#
# DOCKER (postgres + API + dashboard + pgAdmin in one stack):
#     1. fill the three REQUIRED secrets (PUBLIC_URL too, for non-localhost)
#     2. docker compose -f docker/compose.yaml up -d --build
#     3. docker compose -f docker/compose.yaml run --rm migrate
#     Dashboard →  http://localhost:3000
#     Adminer   →  http://localhost:8080
#
# ══════════════════════════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Auth session secret. Generate with: openssl rand -hex 32
# The server refuses to start if this is left as the placeholder value.
BETTER_AUTH_SECRET=change_this_to_something_very_random_and_long

# Column-level encryption key (base64, 32 bytes). Generate with:
#   openssl rand -base64 32
# Used to wrap secrets at rest (RCON passwords, 2FA secrets, etc.).
ORMOD_SECRET_KEY=change_me_openssl_rand_base64_32

# Postgres connection string. Local dev points at your own Postgres on 5432;
# the docker compose stack overrides this inside the container.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ormod

# ── NETWORKING ───────────────────────────────────────────────────────────────

# API port. Default: 3000.
#PORT=3000

# Public URL users access the dashboard at. Leave empty for local dev
# (auto-trusts localhost). REQUIRED for Docker deployments:
#   LAN:           http://192.168.1.100:3000
#   Domain:        http://rcon.example.com
#   HTTPS (proxy): https://rcon.example.com
#PUBLIC_URL=

# Address the API binds to. Default: 0.0.0.0 (all interfaces).
#HOST=0.0.0.0

# When set, the API serves the built dashboard bundle from this path so
# one container can answer both /api/* and /. The docker compose stack
# sets this to /app/apps/web/dist; leave empty for local dev (Vite
# serves the dashboard on :5173).
#SERVE_WEB_DIR=

# ── LOGGING ──────────────────────────────────────────────────────────────────

# Pino log level: trace | debug | info | warn | error | fatal
#LOG_LEVEL=info

# Node environment. Set to 'production' in deployed environments.
#NODE_ENV=development

# ══════════════════════════════════════════════════════════════════════════════
# DOCKER COMPOSE ONLY — ignored when running locally with `pnpm dev`.
# ══════════════════════════════════════════════════════════════════════════════

# Postgres credentials used by the compose stack. The default `postgres`
# user with password `postgres` is fine for local tinkering; change both
# for anything reachable off your machine.
#POSTGRES_USER=postgres
#POSTGRES_PASSWORD=postgres
#POSTGRES_DB=ormod

# Host ports the compose stack binds to. Override if 5432 / 3000 / 8080
# are already in use on the host.
#POSTGRES_HOST_PORT=5432
#APP_HOST_PORT=3000
#ADMINER_HOST_PORT=8080

# Adminer theme. Override to 'price' / 'galkaev' / etc. from
# https://github.com/vrana/adminer/tree/master/designs — any dir name
# in that tree that is bundled in the image works.
#ADMINER_DESIGN=pepa-linha-dark
