# Server
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# Public URL - where users reach the app. Set to your domain and you're done.
PUBLIC_URL=http://localhost:3000
# Only when the dashboard is served from a separate origin (split deploy).
# Leave unset for the normal bundled setup.
WEB_ORIGIN=
# Real client IP header when behind a proxy.
# cloudflare: cf-connecting-ip   nginx: x-real-ip   no proxy: leave unset
TRUSTED_IP_HEADER=

# Datastores
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ormod
REDIS_URL=redis://localhost:6379

# Secrets - generate each with: openssl rand -base64 32
BETTER_AUTH_SECRET=
ORMOD_SECRET_KEY=

# First-run owner. Seeded on first boot as admin@ormod.local with this password;
# you're forced to change it on first login. Optional, defaults to 'changeme'.
OWNER_PASSWORD=changeme

# Optional captcha (leave unset to disable)
# CAPTCHA_PROVIDER=cloudflare-turnstile
# CAPTCHA_SECRET_KEY=
