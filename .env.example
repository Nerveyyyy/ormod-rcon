# ══════════════════════════════════════════════════════════════════════════════
# ORMOD:Directive RCON Dashboard — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and edit the values below.
#
# LOCAL DEV:  Set BETTER_AUTH_SECRET, then: pnpm dev
# DOCKER:     Set BETTER_AUTH_SECRET + PUBLIC_URL, then: docker compose up -d
#
# ══════════════════════════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Auth session encryption key. Generate with: openssl rand -hex 32
# Server refuses to start if this is left as the placeholder value.
BETTER_AUTH_SECRET=change_this_to_something_very_random_and_long

# ── NETWORKING ───────────────────────────────────────────────────────────────

# API port. Default: 3001 (local dev). Docker compose overrides to 3000.
#PORT=3001

# Public URL clients use to reach the dashboard.
# Leave empty for local dev (auto-trusts localhost).
# REQUIRED for Docker — set to the URL users will access:
#   LAN:           http://192.168.1.100:3000
#   Domain:        http://rcon.example.com
#   HTTPS (proxy): https://rcon.example.com
#PUBLIC_URL=

# ── GAME SERVER CONNECTION ───────────────────────────────────────────────────
# How the dashboard reaches the game server. Currently via Docker exec;
# will switch to WebSocket RCON when the game supports it.

# Docker container name the dashboard connects to for command dispatch.
#GAME_CONTAINER_NAME=ormod-server

# ── TLS (optional) ──────────────────────────────────────────────────────────
# For native HTTPS (no reverse proxy): mount certs and set both paths.
# For reverse proxy HTTPS: just set PUBLIC_URL=https://... (no certs needed here).
#TLS_CERT_PATH=/certs/origin.pem
#TLS_KEY_PATH=/certs/origin-key.pem

# ── ADVANCED ─────────────────────────────────────────────────────────────────

# Host port for the dashboard container (Docker). Default: 3000.
#DASHBOARD_PORT=3000

# Database path. Default works for local dev. Docker overrides in compose.
#DATABASE_URL=file:./prisma/ormod-rcon.db

# Pino log level (trace, debug, info, warn, error, fatal).
#LOG_LEVEL=info

# Docker API. Managed by compose files — only set for custom proxy setups.
#DOCKER_HOST=tcp://socket-proxy:2375
#DOCKER_SOCKET=/var/run/docker.sock