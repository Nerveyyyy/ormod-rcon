{
  "name": "@ormod/database",
  "version": "0.0.1",
  "description": "Shared Drizzle schema, client, crypto, and better-auth schema for ormod-rcon.",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./auth": {
      "types": "./dist/auth/config.d.ts",
      "import": "./dist/auth/config.js"
    },
    "./crypto": {
      "types": "./dist/crypto.d.ts",
      "import": "./dist/crypto.js"
    }
  },
  "files": ["dist", "migrations"],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json -w",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest run",
    "db:generate": "pnpm dlx @better-auth/cli@1.6.0 generate --config ./src/auth/instance.ts --adapter drizzle --dialect postgresql --output ./src/schema/auth.ts --yes",
    "db:migrate:gen": "drizzle-kit generate",
    "db:migrate": "tsx ./scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "better-auth": "^1.6.0",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@ormod/config": "workspace:*",
    "drizzle-kit": "^0.31.0"
  }
}
