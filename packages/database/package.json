{
  "name": "@ormod/database",
  "version": "0.0.1",
  "description": "Shared Drizzle schema, client, crypto, and migrations for ormod-rcon.",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./crypto": {
      "types": "./dist/crypto.d.ts",
      "default": "./dist/crypto.js"
    }
  },
  "files": [
    "dist",
    "migrations"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "db:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@ormod/config": "workspace:*",
    "drizzle-kit": "^0.31.0"
  }
}
