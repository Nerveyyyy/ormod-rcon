{
  "extends": "@ormod/config/typescript/base.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"],
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "test/**/*", "vite.config.ts", "vitest.config.ts"],
  "exclude": ["dist", "node_modules"]
}
