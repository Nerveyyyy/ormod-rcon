{
  "name": "@ormod/api",
  "version": "0.0.1",
  "description": "Fastify control API for the ORMOD:Directive RCON dashboard.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenvx run --ignore MISSING_ENV_FILE -- tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "dotenvx run --ignore MISSING_ENV_FILE -- node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.75.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "typebox": "^1.2.18"
  },
  "devDependencies": {
    "@ormod/config": "workspace:*",
    "pino-pretty": "^13.1.3"
  }
}
