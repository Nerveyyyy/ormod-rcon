{
  "name": "@ormod-rcon/api",
  "version": "0.0.1",
  "description": "Fastify API for the ORMOD:Directive RCON dashboard.",
  "private": true,
  "type": "module",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "start": "tsx --env-file=../../.env src/server.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/etag": "^6.1.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/request-context": "^6.2.1",
    "@fastify/sensible": "^6.0.1",
    "@fastify/static": "^8.0.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@fastify/under-pressure": "^9.0.3",
    "@ormod/contracts": "workspace:*",
    "@ormod/database": "workspace:*",
    "@ormod/eventing": "workspace:*",
    "@ormod/rcon-adapter": "workspace:*",
    "@sinclair/typebox": "^0.34.49",
    "better-auth": "^1.6.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "uuidv7": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
