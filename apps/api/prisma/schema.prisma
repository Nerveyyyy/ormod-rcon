// prisma/schema.prisma

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "sqlite"
}

// SQLite does not support native enums — all enum-like fields use String with defined values.

// ═══════════════════════════════════════════════════════════════════════════════
// Auth — BetterAuth schema (email + password, sessions, OAuth-ready)
// Roles: OWNER | ADMIN | VIEWER
// DO NOT CHANGE these models — they are managed by BetterAuth.
// ═══════════════════════════════════════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("VIEWER") // OWNER | ADMIN | VIEWER
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions   Session[]
  accounts   Account[]
  actionLogs ActionLog[]
}

// BetterAuth session — token stored in HTTP-only cookie
model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// BetterAuth account — holds credentials per provider (password stored here)
model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

// BetterAuth verification tokens (email verification, password reset)
model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime?
}

// ═══════════════════════════════════════════════════════════════════════════════
// Game Servers
// ═══════════════════════════════════════════════════════════════════════════════

model Server {
  id            String   @id @default(uuid())
  name          String                        // Display name in UI
  serverName    String   @unique              // Matches -servername flag
  containerName String?                       // Docker container name (null = env default)
  mode          String   @default("DOCKER")   // DOCKER | RCON (RCON reserved for future)
  gamePort      Int      @default(27015)
  queryPort     Int      @default(27016)
  rconPort      Int?                          // null until the game ships RCON
  rconPass      String?
  notes         String?
  createdAt     DateTime @default(now())

  // Player relations
  playerStats    PlayerServerStats[]

  // Event relations
  sessions       PlayerSession[]
  combatLogs     CombatLog[]
  chats          PlayerChat[]
  partySnapshots PartySnapshot[]
  gameEvents     GameEvent[]
  arenaMatches   ArenaMatch[]

  // Existing relations
  wipeLogs       WipeLog[]
  schedules      ScheduledTask[]
  listLinks      ServerListLink[]
  actionLogs     ActionLog[]
}

// ═══════════════════════════════════════════════════════════════════════════════
// Player Identity (global, cross-server)
// ═══════════════════════════════════════════════════════════════════════════════

// Global player identity — one row per unique Steam user across all servers.
// steamId never changes. displayName updated on every join event.
model Player {
  id          String   @id @default(uuid())
  steamId     String   @unique               // Steam ID64, globally unique, never changes
  displayName String                          // Latest known display name (updated on every join)
  firstSeen   DateTime @default(now())        // Earliest join across all servers
  lastSeen    DateTime @default(now())        // Latest activity across all servers

  // Per-server breakdown
  serverStats      PlayerServerStats[]

  // Event relations
  sessions         PlayerSession[]
  combatDeaths     CombatLog[]          @relation("CombatVictim")
  chats            PlayerChat[]
  partyMemberships PartySnapshotMember[]
  arenaEntries     ArenaMatchPlayer[]

  @@index([lastSeen])
}

// Per-server player stats — replaces the old PlayerRecord model.
// Tracks aggregate data for a specific player on a specific server.
model PlayerServerStats {
  id        String   @id @default(uuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  totalTime Int      @default(0)              // Seconds played on this server
  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())
  notes     String?                           // Admin notes about this player on this server

  @@unique([playerId, serverId])
  @@index([serverId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// Player Events
// ═══════════════════════════════════════════════════════════════════════════════

// Tracks individual play sessions (join to leave).
// Created on player.join, closed on player.leave.
model PlayerSession {
  id          String    @id @default(uuid())
  playerId    String
  player      Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  serverId    String
  server      Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  displayName String                          // Snapshot at join time
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?
  reason      String?                         // disconnect | kick | ban | timeout | error
  duration    Int?                            // Seconds, computed on leave

  @@index([playerId, serverId])
  @@index([serverId])
  @@index([joinedAt])
}

// All combat events — PvP kills, PvE deaths, environmental deaths.
// One row per death. For PvP, killerSteamId + killerDisplayName identify the killer.
// To query kills: WHERE killerSteamId IS NOT NULL
// To query deaths for a player: WHERE playerId = X
// killerSteamId is a raw string (not FK) because the killer may be an NPC ("Bear").
model CombatLog {
  id                String   @id @default(uuid())
  serverId          String
  server            Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  playerId          String                    // The player who died
  player            Player   @relation("CombatVictim", fields: [playerId], references: [id], onDelete: Cascade)
  displayName       String                    // Victim display name snapshot at event time
  cause             String                    // "Gunshot", "Fall", "Bear", "Bleeding", etc.
  killerSteamId     String?                   // Raw string — null for PvE/environmental deaths
  killerDisplayName String?                   // Snapshot at event time
  weapon            String?
  locationX         Float?
  locationY         Float?
  locationZ         Float?
  createdAt         DateTime @default(now())

  @@index([playerId, serverId])
  @@index([killerSteamId, serverId])
  @@index([serverId])
  @@index([createdAt])
}

// Chat messages. One row per message sent in any channel.
model PlayerChat {
  id          String   @id @default(uuid())
  serverId    String
  server      Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  playerId    String
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  displayName String                          // Snapshot at message time
  message     String
  channel     String                          // global | team | local
  createdAt   DateTime @default(now())

  @@index([playerId, serverId])
  @@index([serverId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════════
// Party Snapshots (point-in-time party membership)
// ═══════════════════════════════════════════════════════════════════════════════

// Party state at a point in time. Currently requires polling; push event planned.
// Useful for tracking player affiliations (e.g., identifying hacker associates).
model PartySnapshot {
  id            String   @id @default(uuid())
  serverId      String
  server        Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  partyId       String                        // Game-assigned party identifier
  leaderSteamId String                        // Raw string (leader may not have Player record yet)
  capturedAt    DateTime @default(now())

  members PartySnapshotMember[]

  @@index([serverId])
  @@index([leaderSteamId])
  @@index([partyId])
}

// Individual member within a party snapshot.
// Uses playerId FK for queryability ("which parties was player X in?").
model PartySnapshotMember {
  id          String        @id @default(uuid())
  snapshotId  String
  snapshot    PartySnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  playerId    String
  player      Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  displayName String                          // Snapshot at capture time
  isOnline    Boolean

  @@unique([snapshotId, playerId])
  @@index([playerId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// Game Events (merged server + world events)
// ═══════════════════════════════════════════════════════════════════════════════

// All server lifecycle and world state events in one table.
// Filter by name prefix: WHERE name LIKE 'server.%' or 'world.%'
// Event names: server.save | server.restart | server.start | server.shutdown |
//              server.setting.change | world.loot.respawn | world.day.change |
//              world.weather.change | wipe.start
model GameEvent {
  id        String   @id @default(uuid())
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  name      String                            // Dotted event name (e.g., "server.restart", "world.weather.change")
  details   String?                           // JSON string for event-specific data
  createdAt DateTime @default(now())

  @@index([serverId, createdAt])
  @@index([name])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════════════════
// Arena System
// ═══════════════════════════════════════════════════════════════════════════════

// An arena match instance. Created on arena.match.start, updated on arena.match.end.
// @@unique on [serverId, gameMatchId] prevents duplicate match records.
model ArenaMatch {
  id              String             @id @default(uuid())
  serverId        String
  server          Server             @relation(fields: [serverId], references: [id], onDelete: Cascade)
  gameMatchId     String                      // Game-assigned match identifier
  kit             String?
  startedAt       DateTime           @default(now())
  endedAt         DateTime?
  winnerTeam      Int?
  durationSeconds Int?
  scores          String?                     // JSON: {"1": 5, "2": 2}
  participants    ArenaMatchPlayer[]

  @@unique([serverId, gameMatchId])
  @@index([serverId])
}

// Individual participant in an arena match.
// Uses playerId FK + displayName snapshot for consistency with all other event tables.
model ArenaMatchPlayer {
  id          String     @id @default(uuid())
  matchId     String
  match       ArenaMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId    String
  player      Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  displayName String                          // Snapshot at match start
  teamNumber  Int
  respawns    Int        @default(0)

  @@unique([matchId, playerId])
  @@index([playerId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// Access Lists (shareable across servers)
// ═══════════════════════════════════════════════════════════════════════════════

model AccessList {
  id          String   @id @default(uuid())
  name        String                          // e.g. "Global Ban List"
  slug        String   @unique                // URL-safe, auto-generated from name
  type        String                          // BAN | WHITELIST | ADMIN
  scope       String   @default("SERVER")     // GLOBAL | SERVER | EXTERNAL
  description String?
  externalUrl String?                         // EXTERNAL scope: URL to fetch list from
  syncedAt    DateTime?                       // Last external sync timestamp
  createdAt   DateTime @default(now())

  entries     ListEntry[]
  serverLinks ServerListLink[]
}

model ListEntry {
  id         String    @id @default(uuid())
  steamId    String
  playerName String?                          // Cached display name
  reason     String?
  addedBy    String?
  permission String?                          // For ADMIN lists: server | admin | operator | client
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  listId String
  list   AccessList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([steamId, listId])
  @@index([listId])
  @@index([expiresAt])
}

// Link a server to one or more access lists
model ServerListLink {
  serverId String
  listId   String
  server   Server     @relation(fields: [serverId], references: [id], onDelete: Cascade)
  list     AccessList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@id([serverId, listId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// Wipe History
// ═══════════════════════════════════════════════════════════════════════════════

// Records when a wipe command was dispatched and by whom.
// Enriched with type, targetSteamId, durationMs for RCON wipe events.
model WipeLog {
  id            String   @id @default(uuid())
  serverId      String
  server        Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  triggeredBy   String                        // Dashboard user id
  type          String   @default("full")     // full | map | playerdata
  targetSteamId String?                       // For single-player data wipe
  notes         String?
  success       Boolean
  errorMsg      String?
  durationMs    Int?                          // From RCON wipe.complete event
  createdAt     DateTime @default(now())

  @@index([serverId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// Scheduled Tasks
// ═══════════════════════════════════════════════════════════════════════════════

model ScheduledTask {
  id        String    @id @default(uuid())
  serverId  String
  server    Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  type      String                            // COMMAND | RESTART
  cronExpr  String                            // e.g. "0 6 * * 1" = every Monday 6am
  label     String
  slug      String    @unique                 // URL-safe, auto-generated from label
  payload   String                            // COMMAND: the command string. RESTART: empty.
  enabled   Boolean   @default(true)
  lastRun   DateTime?
  nextRun   DateTime?
  createdAt DateTime  @default(now())

  @@index([serverId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// Audit Trail
// ═══════════════════════════════════════════════════════════════════════════════

// Audit trail for all admin actions.
// performedBy stores User.id for dashboard actions, or steamId/"system"/"schedule" for
// non-dashboard sources. User relation is OPTIONAL to support RCON/system sources.
model ActionLog {
  id            String   @id @default(uuid())
  serverId      String?
  server        Server?  @relation(fields: [serverId], references: [id], onDelete: SetNull)
  performedBy   String                        // Human-readable actor: User.id, steamId, "system", "schedule"
  userId        String?                       // FK to User — only set for dashboard-initiated actions
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action        String                        // BAN | UNBAN | KICK | WHITELIST | REMOVEWHITELIST | SETPERMISSION | REMOVEPERMISSION | WIPE | COMMAND | RESTART | SETTINGS_GET | SETTINGS_SET
  targetSteamId String?                       // Player target (null for non-player actions)
  details       String?                       // JSON string for extra context
  reason        String?                       // Human-readable reason for the action
  beforeValue   String?                       // JSON: state before action
  afterValue    String?                       // JSON: state after action
  source        String   @default("dashboard") // dashboard | rcon | schedule | system
  createdAt     DateTime @default(now())

  @@index([serverId])
  @@index([userId])
  @@index([performedBy])
  @@index([targetSteamId])
  @@index([action])
  @@index([createdAt])
}
